# LLM API Configuration
# OpenAI-compatible: set LLM_BASE_URL + LLM_API_KEY + LLM_MODEL
# For Google Gemini: LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# Optional: system prompt for the chatbot
SYSTEM_PROMPT=You are an expert tech support assistant specializing in software solutions and critical problem-solving. Provide clear, actionable answers. Use code examples where relevant.
